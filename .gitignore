# Dependencies
node_modules/

# Build output — Electron main, preload, and the renderer's static
# export. All of `app/` is generated by `npm run dev` (nextron) or by
# `npm run build` (electron-builder). Nothing in here is source.
app/

# Next.js dev cache + export
renderer/.next/
renderer/out/

# electron-builder release artifacts
dist/
release/
out/

# Per-user OS-service pty-host runtime — a BUILD ARTIFACT produced by
# scripts/build-service-runtime.mjs (standalone Node + ABI-matched node-pty).
# Regenerated per OS×arch in CI before packaging; never committed.
resources/runtime/

# OS / editor noise
.DS_Store
Thumbs.db
*.log
.vscode/
.idea/

# Local environment overrides
.env
.env.local

# Test coverage
coverage/
.vitest-cache/

# Playwright E2E output (reports + per-test artifacts)
test-results/
playwright-report/
.playwright/

# TypeScript incremental build state
*.tsbuildinfo
