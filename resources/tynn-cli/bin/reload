#!/usr/bin/env bash
# reload - Clear caches and rebuild the project in the current directory
#
# Usage: reload [--dry-run] [--stack] [--help]
#
# Clears the detected stack's caches and rebuilds its frontend assets, scoped
# to the current working directory. Idempotent — safe to re-run.
#
#   Laravel   php artisan optimize:clear  +  <pm> run build (if a build script exists)
#   Node.js   <pm> run build
#
# Options:
#   --dry-run   Show what would be executed without running
#   --stack     Show detected stack and exit
#   --help      Show this help message
#
# The Node package manager (npm/pnpm/yarn/bun) is auto-detected. See STACKS.md.

set -euo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# Setup
# ─────────────────────────────────────────────────────────────────────────────

# Source bashrc to load aliases
if [[ -f "${HOME}/.bashrc" ]]; then
  source "${HOME}/.bashrc" 2>/dev/null || true
  shopt -s expand_aliases 2>/dev/null || true
fi

# Find script directory and source libraries
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

source "$REPO_ROOT/lib/helpers.sh"
source "$REPO_ROOT/lib/stacks.sh"

# Source config if exists
CONFIG_FILE="$REPO_ROOT/tynn.config"
if [[ -f "$CONFIG_FILE" ]]; then
  source "$CONFIG_FILE"
fi

# ─────────────────────────────────────────────────────────────────────────────
# Flags
# ─────────────────────────────────────────────────────────────────────────────

DRY_RUN=false
SHOW_STACK=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run) DRY_RUN=true; shift ;;
    --stack)   SHOW_STACK=true; shift ;;
    --help|-h)
      sed -n '2,/^$/p' "$0" | sed 's/^# \?//'
      exit 0
      ;;
    *)
      die "Unknown option: $1"
      ;;
  esac
done

# ─────────────────────────────────────────────────────────────────────────────
# Execution wrapper (respects --dry-run)
# ─────────────────────────────────────────────────────────────────────────────

run() {
  if [[ "$DRY_RUN" == true ]]; then
    log "[dry-run] $*"
  else
    log "Running: $*"
    "$@"
  fi
}

# ─────────────────────────────────────────────────────────────────────────────
# Frontend build (shared by every stack that ships JS assets)
# ─────────────────────────────────────────────────────────────────────────────

# True when package.json declares a "build" script in the current directory
node_has_build_script() {
  [[ -f "package.json" ]] || return 1
  grep -Eq '"build"[[:space:]]*:' package.json 2>/dev/null
}

# Rebuild frontend assets with the detected package manager
rebuild_frontend() {
  local pm_run
  pm_run=$(node_pm_run)
  run $pm_run build
}

# ─────────────────────────────────────────────────────────────────────────────
# Reload handlers for each stack
# ─────────────────────────────────────────────────────────────────────────────

reload_laravel() {
  local php
  php=$(php_cmd)

  # Verify PHP is available
  if ! $php --version >/dev/null 2>&1; then
    die "PHP not found. Checked: Herd, Laragon, XAMPP, WAMP, scoop, PATH"
  fi

  # Clear all Laravel caches (config, route, view, event, compiled)
  run $php artisan optimize:clear

  # Rebuild frontend assets if this app has a JS build
  if node_has_build_script; then
    rebuild_frontend
  else
    info "No package.json build script — skipping frontend build"
  fi

  ok "Laravel caches cleared and assets rebuilt"
}

reload_node() {
  if ! node_has_build_script; then
    die "No \"build\" script found in package.json — nothing to rebuild"
  fi

  rebuild_frontend

  ok "Frontend assets rebuilt"
}

# ─────────────────────────────────────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────────────────────────────────────

main() {
  local stack
  stack=$(detect_stack)

  if [[ "$SHOW_STACK" == true ]]; then
    echo "Detected stack: $(stack_name "$stack") ($stack)"
    exit 0
  fi

  if [[ "$stack" == "$STACK_UNKNOWN" ]]; then
    die "Could not detect project stack. Run reload from your project root. See STACKS.md."
  fi

  # Check stack restrictions
  if ! is_stack_allowed "$stack"; then
    die "Stack '$stack' is not allowed by your tynn.config"
  fi

  log "Detected stack: $(stack_name "$stack")"

  case "$stack" in
    "$STACK_LARAVEL")
      reload_laravel
      ;;
    "$STACK_NODE"|"$STACK_NODE_PRISMA"|"$STACK_NODE_DRIZZLE"|"$STACK_NODE_KNEX"|"$STACK_NODE_SEQUELIZE"|"$STACK_NODE_TYPEORM")
      reload_node
      ;;
    *)
      die "reload is not defined for stack: $(stack_name "$stack"). Supported: Laravel, Node.js."
      ;;
  esac
}

main
